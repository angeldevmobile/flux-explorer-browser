{
  "name": "orion-backend",
  "version": "1.0.0-beta.1",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "build:exe": "npm run build && pkg dist/index.js --target node22-win-x64 --output ../flux-engine/bin/flux-backend.exe",
    "start": "node dist/index.js",
    "postbuild:exe": "node -e \"const fs=require('fs'),src='node_modules/better-sqlite3/build/Release/better_sqlite3.node',dst='../flux-engine/bin/better_sqlite3.node';if(fs.existsSync(src)){fs.copyFileSync(src,dst);console.log('Copied better_sqlite3.node');}else{console.warn('better_sqlite3.node not found at',src);}\""
  },
  "pkg": {
    "assets": [
      "node_modules/better-sqlite3/build/Release/*.node"
    ],
    "scripts": [
      "dist/**/*.js"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@google-cloud/text-to-speech": "^6.4.0",
    "@google/generative-ai": "^0.24.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^9.6.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.16.5",
    "@yao-pkg/pkg": "^5.12.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}
